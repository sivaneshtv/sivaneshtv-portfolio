---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sticky from '../components/artifacts/Sticky.astro';
import IndexCard from '../components/artifacts/IndexCard.astro';
import Polaroid from '../components/artifacts/Polaroid.astro';
import Printout from '../components/artifacts/Printout.astro';
import Marker from '../components/artifacts/Marker.astro';
import ContactCard from '../components/artifacts/ContactCard.astro';
import PhotoFrame from '../components/artifacts/PhotoFrame.astro';
import profileImg from '../assets/workbench/Profile image.jpeg';
import TodoList from '../components/artifacts/TodoList.astro';
import ZoneLabel from '../components/artifacts/ZoneLabel.astro';
import Masthead from '../components/artifacts/Masthead.astro';
---

<BaseLayout title="Component Showcase">
  <div style="background:#e8e4db;min-height:100vh;overflow:auto;padding:60px 80px 200px;">

    <h2 style="font-family:var(--fm);font-size:12px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-3);margin-bottom:40px;">Component Showcase — Phase 2 Gate</h2>

    <!-- 1. Sticky (yellow default) -->
    <div style="position:relative;height:320px;margin-bottom:60px;">
      <Sticky variant="yellow" width={260} rotation={2} eyebrow="— what I hold to —">
        Structure <em>before</em> style. Always. Style is how structure <em>shows itself.</em>
      </Sticky>
    </div>

    <!-- 2. Sticky (pink) -->
    <div style="position:relative;height:320px;margin-bottom:60px;">
      <Sticky variant="pink" width={300} rotation={-3} eyebrow="— in my own words —">
        A product designer who cares about <em>structure</em> more than surface. Happiest when the problem is fuzzy, the stakes are real, and the answer is a rule — not a mood board.
      </Sticky>
    </div>

    <!-- 3. Sticky (green) -->
    <div style="position:relative;height:280px;margin-bottom:60px;">
      <Sticky variant="green" width={240} rotation={1} eyebrow="— always on —">
        Can't get through a day without good music. Obsessed.
      </Sticky>
    </div>

    <!-- 4. Index Card -->
    <div style="position:relative;height:380px;margin-bottom:60px;">
      <IndexCard
        rotation={-1.5}
        title='how <em>I</em> actually work'
        sub="— typical week —"
        rows={[
          { label: 'Sit close with CS + PM', value: 'calls, transcripts' },
          { label: 'Turn findings into structure', value: 'IA, flows, rules' },
          { label: 'Prototype in the real tool', value: 'Figma / Claude / Lovable' },
          { label: 'Pair with engineering', value: 'daily, ship weeks' },
          { label: 'Deep work', value: '<em>10:00 – 14:00 IST</em>' },
          { label: 'Collab hours', value: '15:00 – 18:00 IST' },
        ]}
      />
    </div>

    <!-- 5. Polaroid -->
    <div style="position:relative;height:480px;margin-bottom:60px;">
      <Polaroid
        rotation={-3}
        caption='Cockpit View <em>2.0</em>'
        meta="2026 · Drone Autonomy"
      >
        <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
          <rect width="400" height="300" fill="#1a1a1c"/>
          <circle cx="200" cy="150" r="60" stroke="#3a7dd0" stroke-width="2" fill="none" opacity=".6"/>
          <circle cx="200" cy="150" r="30" stroke="#3a7dd0" stroke-width="1.5" fill="none" opacity=".4"/>
        </svg>
      </Polaroid>
    </div>

    <!-- 6. Printout -->
    <div style="position:relative;height:440px;margin-bottom:60px;">
      <Printout
        rotation={2}
        url="app.flytbase.com/cockpit"
        label='Cockpit View <em>2.0</em> — v2 beta'
        labelMeta="screenshot, v2.0 beta"
      >
        <svg viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg">
          <rect width="800" height="500" fill="#1a1a1c"/>
          <text x="400" y="250" fill="#4a4945" font-family="JetBrains Mono" font-size="12" text-anchor="middle">SCREENSHOT PLACEHOLDER</text>
        </svg>
      </Printout>
    </div>

    <!-- 7. Markers (all sizes) -->
    <div style="position:relative;height:200px;margin-bottom:60px;">
      <Marker size="sm" variant="red" rotation={-4}>click any to open ↓</Marker>
      <Marker size="md" variant="blue" rotation={6} pos={{x:300, y:20}}>↗ see the diagram</Marker>
      <Marker size="lg" variant="black" rotation={-2} pos={{x:0, y:80}}>the work →</Marker>
    </div>

    <!-- 8. Contact Card -->
    <div style="position:relative;height:340px;margin-bottom:60px;">
      <ContactCard
        title='if this <em>clicked</em> — say hi.'
        body="Taking briefs in Q2 '26. Short contracts, design lead roles, advisory, pair-thinking sessions. Drop a line — I read everything."
        email="hello@sivanesh.tv"
        emailHref="mailto:sssiva.1999@gmail.com"
        socials={[
          { label: 'LinkedIn', url: 'https://www.linkedin.com/in/sivanesh-t-v-product-designer' },
          { label: 'Read.cv', url: '/assets/sivanesh-tv-resume.pdf' },
          { label: 'Twitter', url: 'https://x.com/dunkadamics' },
        ]}
      />
    </div>

    <!-- 9. Photo Frame -->
    <div style="position:relative;height:260px;margin-bottom:60px;">
      <PhotoFrame rotation={-5} caption="— that's me, Chennai IN —">
        <img src={profileImg.src} alt="Sivanesh TV" />
      </PhotoFrame>
    </div>

    <!-- 10. Todo List -->
    <div style="position:relative;height:380px;margin-bottom:60px;">
      <TodoList
        rotation={1.5}
        title='what I <em>practice</em>'
        sub="— the verbs —"
        items={[
          { text: 'Absorb', done: true },
          { text: 'Structure', done: true },
          { text: 'Prototype', done: true },
          { text: 'Systematise', done: true },
          { text: 'Ship', done: true },
          { text: 'Critique', done: true },
        ]}
      />
    </div>

    <!-- 11. Zone Label -->
    <div style="position:relative;height:140px;margin-bottom:60px;">
      <ZoneLabel size={96} rotation={-1}>— hello —</ZoneLabel>
    </div>
    <div style="position:relative;height:140px;margin-bottom:60px;">
      <ZoneLabel size={96} rotation={1}>the <em>work</em></ZoneLabel>
    </div>

    <!-- 12. Masthead -->
    <div style="position:relative;height:400px;margin-bottom:60px;">
      <Masthead
        eyebrow="hey, I'm —"
        title='Sivanesh <em>TV</em>,<br>a designer<br>who <span class="strike">talks</span> <em>ships.</em>'
        sub='Product design for <em>critical operations</em> — drone autonomy, fleet tools, interfaces where a wrong tap costs more than time. Based in Chennai · open to briefs.'
      />
    </div>

  </div>
</BaseLayout>

<style is:global>
  /* Override body overflow for showcase scrolling */
  body { overflow: auto !important; user-select: auto !important; -webkit-user-select: auto !important; touch-action: auto !important; }
</style>
