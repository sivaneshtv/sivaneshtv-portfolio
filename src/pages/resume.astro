---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Resume — Sivanesh TV"
  description="Product Designer resume — Sivanesh TV. Safety-critical systems, fleet tools, infrastructure management. Based in Chennai."
>
  <main class="wrap">
    <a class="back" href="/">← sivanesh.tv</a>

    <div class="card">
      <div class="eyebrow">— resume —</div>
      <div class="name">Sivanesh <em>TV</em></div>
      <div class="role">Product Designer · Chennai, IN</div>

      <div class="actions">
        <a class="btn btn-primary" href="/resume.pdf" target="_blank" rel="noopener">
          View PDF
          <span class="arr">↗</span>
        </a>
        <a class="btn btn-ghost" href="/resume.pdf" download="Sivanesh-TV-Resume.pdf">
          Download
          <span class="arr">↓</span>
        </a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  *,*::before,*::after{margin:0;padding:0;box-sizing:border-box}

  .wrap {
    min-height: 100vh;
    background: #1a1a1c;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
    font-family: 'Inter', sans-serif;
    position: relative;
    overflow: hidden;
  }

  /* Subtle dot grid */
  .wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  /* Ghosted S texture */
  .wrap::after {
    content: 'S';
    position: absolute;
    right: -80px;
    top: 50%;
    transform: translateY(-55%);
    font-family: 'Caveat', cursive;
    font-size: 600px;
    font-weight: 700;
    color: #e84a3f;
    opacity: 0.04;
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .back {
    position: fixed;
    top: 28px;
    left: 28px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #4a4945;
    text-decoration: none;
    transition: color 0.18s;
    z-index: 10;
  }

  .back:hover { color: #8a867e; }

  .card {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #3a3835;
    margin-bottom: 20px;
  }

  .name {
    font-family: 'Caveat', cursive;
    font-weight: 700;
    font-size: clamp(72px, 12vw, 120px);
    line-height: 0.95;
    color: #f0ece4;
    letter-spacing: -1px;
  }

  .name em {
    font-style: italic;
    color: #e84a3f;
  }

  .role {
    margin-top: 14px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #4a4945;
  }

  .actions {
    margin-top: 44px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 28px;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
    cursor: pointer;
  }

  .btn-primary {
    background: #e84a3f;
    color: #fff;
    border: 1px solid #e84a3f;
  }

  .btn-primary:hover {
    background: #d03d33;
    border-color: #d03d33;
  }

  .btn-ghost {
    background: transparent;
    color: #5e5a52;
    border: 1px dashed #2e2e30;
  }

  .btn-ghost:hover {
    border-color: #4a4945;
    color: #8a867e;
  }

  .arr {
    opacity: 0.7;
  }

  @media (max-width: 480px) {
    .back { top: 20px; left: 20px; }
    .actions { flex-direction: column; width: 100%; }
    .btn { justify-content: center; }
  }
</style>
