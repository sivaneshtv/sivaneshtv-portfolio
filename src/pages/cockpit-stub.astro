---
import CaseLayout from '../layouts/CaseLayout.astro';
import ReaderColumn from '../components/reader/ReaderColumn.astro';
import Back from '../components/reader/Back.astro';
import Hero from '../components/reader/Hero.astro';
import MetaRow from '../components/reader/MetaRow.astro';
import Section from '../components/reader/Section.astro';
import SectionLabel from '../components/reader/SectionLabel.astro';
import H2 from '../components/reader/H2.astro';
import Lead from '../components/reader/Lead.astro';
import Body from '../components/reader/Body.astro';
import Sticky from '../components/artifacts/Sticky.astro';
---

<CaseLayout title="Cockpit View 2.0 — Sivanesh TV" caseNum="01" caseName="Cockpit View 2.0">
  <Fragment slot="reader">
    <ReaderColumn>
      <Back />
      <Hero
        eyebrow="— case study · 01 —"
        title='Cockpit <em>View</em> 2.0'
        sub="Redesigning the primary control interface for autonomous drone operations — from the ground up."
      />
      <MetaRow items={[
        { k: 'Role', v: 'Lead · with Prathamesh' },
        { k: 'Year', v: '2024' },
        { k: 'Scope', v: 'End-to-end UX · Design system' },
        { k: 'Tools', v: 'Figma · Claude · Lovable' },
      ]} />

      <Section>
        <SectionLabel text="Context" num="§ 01" />
        <H2>Cockpit View is the <em>primary interface</em> operators live in all day.</H2>
        <Lead>It runs entirely in a browser — no native app, no dedicated hardware — and it has to perform like both a map and a command centre simultaneously.</Lead>
        <Body>
          <p>Professional drone operators use Cockpit View to control autonomous flights, monitor live video, manage missions, and respond to in-flight events. Every shift is hours long. Every alert matters.</p>
          <p>The v1 interface was built for a single drone. By the time I joined, operators were running multiple sites, responding to alerts from integrations fired at any hour, and beginning to prepare for regulatory one-to-many waivers. The interface hadn't caught up.</p>
        </Body>
      </Section>

      <Section>
        <SectionLabel text="The problem" num="§ 02" />
        <H2>The interface was working. The <em>operators</em> were doing the work it should have been doing.</H2>
        <Body>
          <p>When we sat in on CS calls and read the transcripts, a pattern emerged. Operators were compensating — memorising which panel held which control, ignoring alerts they'd learned to filter out.</p>
        </Body>
      </Section>
    </ReaderColumn>
  </Fragment>

  <Fragment slot="artifacts">
    <!-- Artifact anchored to section 0 -->
    <div class="sticky pink artifact" data-anchor="0" data-anchor-offset="40" data-side="right" data-gap="80" data-width="280"
      style="position:absolute;width:280px;min-height:180px;padding:22px 20px 18px;font-family:var(--fh);font-weight:500;font-size:20px;line-height:1.35;color:var(--ink);background:var(--pink);box-shadow:2px 4px 0 rgba(40,35,25,.05),4px 8px 16px rgba(40,35,25,.18);transform:rotate(-3deg)">
      <div style="font-family:var(--fm);font-size:9px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);margin-bottom:8px">— stub artifact —</div>
      This sticky should appear next to § 01, on the right side of the reader column.
    </div>

    <!-- Artifact anchored to section 1 -->
    <div class="sticky green artifact" data-anchor="1" data-anchor-offset="20" data-side="left" data-gap="60" data-width="260"
      style="position:absolute;width:260px;min-height:180px;padding:22px 20px 18px;font-family:var(--fh);font-weight:500;font-size:20px;line-height:1.35;color:var(--ink);background:#b5e0b5;box-shadow:2px 4px 0 rgba(40,35,25,.05),4px 8px 16px rgba(40,35,25,.18);transform:rotate(2deg)">
      <div style="font-family:var(--fm);font-size:9px;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);margin-bottom:8px">— anchored to § 02 —</div>
      This one should appear next to § 02, on the left side.
    </div>
  </Fragment>
</CaseLayout>
