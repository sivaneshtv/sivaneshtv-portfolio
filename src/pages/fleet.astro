          <g fill="#1a1a1c"><rect x="12" y="27" width="160" height="5"/><rect x="12" y="34" width="160" height="5"/><rect x="12" y="41" width="160" height="5"/><rect x="12" y="48" width="160" height="5"/></g>
          <rect x="0" y="58" width="180" height="15" fill="#a8d0f0" opacity=".3"/>
