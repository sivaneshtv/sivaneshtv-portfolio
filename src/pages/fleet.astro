    <!-- §04 INTERFACE — real 4-panel printout -->
    <div class="printout artifact" id="obj-four-panel" data-anchor="3" data-anchor-offset="160" data-side="right" data-gap="60" data-width="460" style="position:absolute;width:460px;transform:rotate(2deg);padding:12px;background:#fbfaf4;box-shadow:2px 3px 0 rgba(40,35,25,.05),5px 10px 22px rgba(40,35,25,.22)">
