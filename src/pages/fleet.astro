        <!-- Group by Site -->
        <g transform="translate(10 10)">
          <text x="0" y="0" font-family="JetBrains Mono" font-size="9" fill="#d8352a" letter-spacing="1">GROUP BY: SITE</text>
          <rect x="0" y="8" width="180" height="15" fill="#f5c84a" opacity=".3"/>
