          <rect x="0" y="76" width="180" height="15" fill="#b5e0b5" opacity=".3"/>
          <text x="6" y="87" font-family="JetBrains Mono" font-size="8" fill="#1a1a1c">▸ SITE-C · 2 drones</text>
        </g>

        <!-- Group by Pilot -->
        <g transform="translate(230 10)">
          <text x="0" y="0" font-family="JetBrains Mono" font-size="9" fill="#d8352a" letter-spacing="1">GROUP BY: PILOT</text>
          <rect x="0" y="8" width="180" height="15" fill="#f5c84a" opacity=".3"/>
          <text x="6" y="19" font-family="JetBrains Mono" font-size="8" fill="#1a1a1c">▾ SARAH · 4 drones</text>
          <g fill="#1a1a1c"><rect x="12" y="27" width="160" height="5"/><rect x="12" y="34" width="160" height="5"/><rect x="12" y="41" width="160" height="5"/><rect x="12" y="48" width="160" height="5"/></g>
          <rect x="0" y="58" width="180" height="15" fill="#a8d0f0" opacity=".3"/>
          <text x="6" y="69" font-family="JetBrains Mono" font-size="8" fill="#1a1a1c">▸ RAJ · 3 drones</text>
          <rect x="0" y="76" width="180" height="15" fill="#b5e0b5" opacity=".3"/>
          <text x="6" y="87" font-family="JetBrains Mono" font-size="8" fill="#1a1a1c">▸ UNASSIGNED · 2</text>
        </g>

        <!-- Key insight -->
        <g transform="translate(0 130)">
          <line x1="20" y1="0" x2="400" y2="0" stroke="#1a1a1c" stroke-width=".5" stroke-dasharray="3 2"/>
          <text x="210" y="24" text-anchor="middle" font-family="Caveat" font-size="16" fill="#1a1a1c" font-weight="700">every drone is still counted.</text>
          <text x="210" y="46" text-anchor="middle" font-family="Caveat" font-size="16" fill="#d8352a" font-weight="700">collapsed ≠ hidden.</text>
