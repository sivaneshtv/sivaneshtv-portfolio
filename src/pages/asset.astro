          <line x1="90" y1="63" x2="90" y2="123" stroke="#d8352a" stroke-width=".9"/>
          <line x1="90" y1="63" x2="150" y2="113" stroke="#d8352a" stroke-width=".9"/>
          <line x1="90" y1="63" x2="30" y2="163" stroke="#d8352a" stroke-width=".9"/>
          <line x1="90" y1="63" x2="150" y2="163" stroke="#d8352a" stroke-width=".9"/>
