          <text x="30" y="123" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-2)">inspections</text>
          <rect x="70" y="123" width="40" height="14" rx="2" fill="none" style="stroke:var(--ink-2)" stroke-width="1"/>
          <text x="90" y="133" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-2)">media</text>
          <rect x="128" y="113" width="44" height="14" rx="2" fill="none" style="stroke:var(--ink-2)" stroke-width="1"/>
          <text x="150" y="123" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-2)">profiles</text>
          <rect x="10" y="163" width="40" height="14" rx="2" fill="none" style="stroke:var(--ink-2)" stroke-width="1"/>
          <text x="30" y="173" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-2)">alerts</text>
          <rect x="128" y="163" width="44" height="14" rx="2" fill="none" style="stroke:var(--ink-2)" stroke-width="1"/>
          <text x="150" y="173" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-2)">reports</text>
