          <text x="30" y="123" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-2)">waypoints</text>
          <rect x="70" y="123" width="40" height="14" rx="2" fill="none" style="stroke:var(--ink-2)" stroke-width="1"/>
          <text x="90" y="133" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-2)">media</text>
          <rect x="130" y="113" width="40" height="14" rx="2" fill="none" style="stroke:var(--ink-2)" stroke-width="1"/>
          <text x="150" y="123" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-2)">telemetry</text>
          <line x1="90" y1="63" x2="30" y2="113" style="stroke:var(--ink-2)" stroke-width=".7"/>
          <line x1="90" y1="63" x2="90" y2="123" style="stroke:var(--ink-2)" stroke-width=".7"/>
          <line x1="90" y1="63" x2="150" y2="113" style="stroke:var(--ink-2)" stroke-width=".7"/>
          <!-- asset as ghost -->
          <rect x="70" y="167" width="40" height="16" rx="2" fill="none" style="stroke:var(--ink-3)" stroke-width=".5" stroke-dasharray="2 2" opacity=".5"/>
          <text x="90" y="178" text-anchor="middle" font-family="Inter" font-size="7" style="fill:var(--ink-3)" opacity=".6">"asset"</text>
          <text x="90" y="210" text-anchor="middle" font-family="Caveat" font-size="13" fill="#7a7770">asset = string in mission name</text>
        </g>
        <!-- divider -->
        <line x1="210" y1="30" x2="210" y2="240" stroke="#1a1a1c" stroke-width=".5" stroke-dasharray="2 3" opacity=".5"/>
        <!-- After: asset-first -->
        <g transform="translate(220 20)">
          <text x="90" y="0" text-anchor="middle" font-family="JetBrains Mono" font-size="9" fill="#d8352a" letter-spacing="1">AFTER — ASSET-FIRST</text>
          <rect x="63" y="37" width="54" height="26" rx="3" fill="#d8352a"/>
          <text x="90" y="54" text-anchor="middle" font-family="Inter" font-size="10" fill="#fdf8ea" font-weight="700">ASSET</text>
