        </g>
      </svg>
    </div>

    <!-- §04 TEMPLATIZATION — the payoff principle -->
    <div class="principle artifact" id="obj-template-principle" data-anchor="3" data-anchor-offset="40" data-side="right" data-gap="80" data-width="380" style="position:absolute;transform:rotate(-1.5deg);width:380px;padding:32px 32px 28px;background:var(--paper);box-shadow:3px 5px 0 rgba(40,35,25,.06),6px 14px 28px rgba(40,35,25,.2);border:1px solid rgba(40,35,25,.08)">
      <div style="position:absolute;top:-12px;right:10%;width:90px;height:22px;background:var(--tape);opacity:.85;transform:rotate(3deg);box-shadow:0 2px 6px rgba(40,35,25,.1)"></div>
