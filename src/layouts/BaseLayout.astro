---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = 'Product design for critical operations — safety-critical systems, fleet tools, infrastructure management. Based in Chennai, open to briefs.',
  ogImage = '/og.png',
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageAbsolute = new URL(ogImage, Astro.site).toString();

// Base Person schema — present on every page
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Sivanesh TV',
  url: 'https://sivanesh.tv',
  jobTitle: 'Product Designer',
  description,
  sameAs: [
    'https://www.linkedin.com/in/sivanesh-t-v-product-designer',
    'https://x.com/dunkadamics',
  ],
};

const schemas = [personSchema, ...(jsonLd ? [jsonLd] : [])];
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Apply saved theme before first paint to avoid flash -->
    <script is:inline>
      (function(){var t=localStorage.getItem('sivanesh.theme')||'dark';document.documentElement.setAttribute('data-theme',t)})();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#1a1a1c" />

    <!-- Open Graph (LinkedIn, Slack, iMessage, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sivanesh TV" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbsolute} />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@dunkadamics" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbsolute} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(schemas.length === 1 ? schemas[0] : schemas)} />

    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/JetBrainsMono[wght].woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <!-- Shared wobble filter — one per page, referenced by all arrows -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <defs>
        <filter id="wobble">
          <feTurbulence baseFrequency=".04" numOctaves="2" result="noise"/>
          <feDisplacementMap in="SourceGraphic" in2="noise" scale="2"/>
        </filter>
      </defs>
    </svg>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/base.css';
  @import '../styles/canvas.css';
</style>
