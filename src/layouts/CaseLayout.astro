---
import BaseLayout from './BaseLayout.astro';
import ReadingHint from '../components/canvas/ReadingHint.astro';

interface Props {
  title: string;
  caseNum: string;
  caseName: string;
  backHref?: string;
}

const { title, caseNum, caseName, backHref = '/#work' } = Astro.props;
---

<BaseLayout title={title}>
  <!-- Opening transition — polaroid zoom intro -->
  <slot name="opening" />

  <div class="board-bg"></div>

  <div class="canvas-wrap" id="canvasWrap">
    <div class="canvas" id="canvas" style="width:5000px;height:6800px">
      <slot name="reader" />
      <slot name="artifacts" />
    </div>
  </div>

  <!-- Case topbar — same structure as workbench, case title instead of "the workbench" -->
  <div class="topbar">
    <div class="tb-logo-wrap">
      <a href={backHref} class="tb-logo" title="Back to workbench">
        <span class="back-ic"><svg viewBox="0 0 14 14" width="12" height="12"><path d="M9 3L4 7l5 4" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        <span>Sivanesh.tv</span>
        <span class="tb-logo-sub">— {caseName}</span>
      </a>
    </div>
    <a href="/#contact" class="tb-contact">Contact ↗</a>
  </div>

  <!-- Toolbar (same as workbench) -->
  <div class="toolbar">
    <button class="tb-btn" id="btnZoomOut" title="Zoom out (−)">−</button>
    <div class="tb-zoom" id="zoomVal">100%</div>
    <button class="tb-btn" id="btnZoomIn" title="Zoom in (+)">+</button>
    <div class="tb-divider"></div>
    <button class="tb-btn" id="themeToggle" title="Toggle theme"><svg viewBox="0 0 16 16" width="12" height="12"><circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.2" fill="none"/><path d="M8 2.5a5.5 5.5 0 0 1 0 11z" fill="currentColor"/></svg></button>
    <button class="tb-btn" id="btnFit" title="Fit (F)"><svg viewBox="0 0 16 16" width="12" height="12"><path d="M2 5V2h3 M11 2h3v3 M14 11v3h-3 M5 14H2v-3" stroke="currentColor" stroke-width="1.4" fill="none" stroke-linecap="round"/></svg></button>
    <button class="tb-btn" id="btnReader" title="Reading view (R)"><svg viewBox="0 0 16 16" width="12" height="12"><rect x="3" y="2" width="10" height="12" stroke="currentColor" stroke-width="1.2" fill="none"/><line x1="5" y1="5" x2="11" y2="5" stroke="currentColor" stroke-width="1.2"/><line x1="5" y1="8" x2="11" y2="8" stroke="currentColor" stroke-width="1.2"/><line x1="5" y1="11" x2="9" y2="11" stroke="currentColor" stroke-width="1.2"/></svg></button>
  </div>

  <!-- Minimap -->
  <div class="minimap" id="minimap" title="Click to jump">
    <div class="minimap-label">Board</div>
    <div class="minimap-canvas" id="minimapCanvas"></div>
    <div class="minimap-viewport" id="minimapViewport"></div>
  </div>

  <!-- Mobile hint -->
  <div class="mobile-hint" id="mobileHint">pinch to zoom · drag to pan</div>

  <!-- Reading hint -->
  <ReadingHint />

  <!-- Return pill (margin-ref jump feedback) -->
  <div class="return-pill" id="returnPill" role="status" aria-live="polite">
    <button class="return-pill-btn" id="returnPillBtn">Return to study</button>
    <button class="return-pill-close" id="returnPillClose" aria-label="Dismiss">×</button>
  </div>
  <!-- Hidden span for engine to write label into (used by data-label toast logic) -->
  <span id="returnPillArtifact" hidden></span>
</BaseLayout>

<style is:global>
  /* §6.1 — Topbar */
  .topbar{position:fixed;top:0;left:0;right:0;z-index:30;display:flex;justify-content:space-between;align-items:center;padding:20px 28px;pointer-events:none}
  .topbar > *{pointer-events:auto}
  .tb-logo-wrap{position:relative}
  .tb-logo{display:flex;align-items:center;gap:10px;font-family:var(--fs);font-weight:600;font-size:14px;color:var(--ink);background:rgba(232,228,219,.92);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);padding:8px 12px 8px 10px;border:1px solid rgba(40,35,25,.12);box-shadow:0 4px 14px rgba(40,35,25,.08);cursor:pointer;transition:background .2s,border-color .2s;text-decoration:none}
  .tb-logo:hover{background:rgba(232,228,219,1);border-color:rgba(40,35,25,.25)}
  .tb-logo-sub{color:var(--ink-3);font-weight:400;font-size:12px}
  .back-ic{display:inline-flex;align-items:center;justify-content:center;width:14px;color:var(--ink-2);transition:transform .2s,color .2s}
  .tb-logo:hover .back-ic{transform:translateX(-2px);color:var(--red)}
  .tb-contact{
    display:flex;align-items:center;
    font-family:var(--fm);font-size:10px;letter-spacing:.14em;text-transform:uppercase;
    color:#fff;background:var(--red);
    border:1px solid #b82b22;
    padding:8px 12px;text-decoration:none;
    box-shadow:0 4px 14px rgba(40,35,25,.08);
    height:39px;box-sizing:border-box;
    transition:background .2s,border-color .2s;
  }
  .tb-contact:hover{background:#b82b22;border-color:#b82b22}
  .toolbar{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);z-index:30;display:flex;align-items:center;gap:2px;background:rgba(232,228,219,.92);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid rgba(40,35,25,.12);padding:6px;box-shadow:0 8px 30px rgba(40,35,25,.15),0 2px 6px rgba(40,35,25,.08)}
  .tb-divider{width:1px;height:22px;background:rgba(40,35,25,.15);margin:0 4px;flex-shrink:0}
  .tb-btn{display:flex;align-items:center;justify-content:center;width:36px;height:36px;font-family:var(--fm);font-size:13px;color:var(--ink-2);transition:background .2s,color .2s;border-radius:2px}
  .tb-btn:hover{background:rgba(40,35,25,.08);color:var(--ink)}
  .tb-btn svg{display:block}
  .tb-zoom{font-family:var(--fm);font-size:11px;letter-spacing:.08em;color:var(--ink-2);padding:0 12px;min-width:58px;text-align:center}
  .minimap{position:fixed;bottom:20px;right:20px;z-index:30;width:160px;height:112px;background:rgba(232,228,219,.92);backdrop-filter:blur(12px);border:1px solid rgba(40,35,25,.15);box-shadow:0 4px 16px rgba(40,35,25,.12);overflow:hidden;cursor:pointer}
  .minimap-canvas{position:absolute;inset:4px;background:transparent}
  .minimap-dot{position:absolute;background:var(--ink);border-radius:1px;opacity:.55}
  .minimap-dot.work{background:var(--marker-red);opacity:.75}
  .minimap-viewport{position:absolute;border:1.5px solid var(--marker-red);background:rgba(216,53,42,.08);pointer-events:none;transition:none}
  .minimap-label{position:absolute;top:4px;left:8px;font-family:var(--fm);font-size:8px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-3);pointer-events:none}
  .mobile-hint{display:none;position:fixed;bottom:90px;left:50%;transform:translateX(-50%);z-index:25;background:#1a1a1c;color:#f5ede0;padding:10px 16px;font-family:var(--fm);font-size:10px;letter-spacing:.14em;text-transform:uppercase;box-shadow:0 4px 16px rgba(40,35,25,.25);white-space:nowrap;opacity:0;transition:opacity .4s ease;pointer-events:none}
  .mobile-hint.on{opacity:1}
  @media(max-width:820px){
    .topbar{padding:14px 16px;flex-wrap:wrap;gap:10px}
    .tb-logo{padding:6px 10px;font-size:12px}
    .tb-logo-sub{display:none}
    .tb-contact{font-size:9px;height:32px;padding:0 10px}
    .toolbar{bottom:12px;padding:4px;gap:1px}
    .tb-btn{width:32px;height:32px}
    .tb-zoom{padding:0 6px;min-width:46px;font-size:10px}
    .tb-divider{height:18px;margin:0 2px}
    .minimap{width:96px;height:68px;bottom:62px;right:12px}
    .mobile-hint{display:block}
  }
  @media(prefers-reduced-motion:reduce){
    *,*::before,*::after{animation-duration:.01ms!important;transition-duration:.01ms!important}
  }

  /* Return pill */
  .return-pill{
    position:fixed;bottom:80px;left:50%;transform:translateX(-50%) translateY(8px);z-index:40;
    display:flex;align-items:center;gap:8px;
    background:rgba(26,26,28,.94);color:#f5ede0;
    padding:8px;
    font-family:var(--fm);font-size:10px;letter-spacing:.14em;text-transform:uppercase;
    white-space:nowrap;
    box-shadow:0 8px 24px rgba(40,35,25,.3);
    opacity:0;pointer-events:none;
    transition:opacity .3s ease,transform .3s ease;
  }
  .return-pill.on{opacity:1;pointer-events:auto;transform:translateX(-50%) translateY(0)}
  .return-pill-btn{
    font-family:var(--fm);font-size:10px;letter-spacing:.14em;text-transform:uppercase;
    color:#fff;background:var(--red);border:none;padding:7px 12px;cursor:pointer;transition:background .2s;
  }
  .return-pill-btn:hover{background:#b82b22}
  .return-pill-close{
    display:flex;align-items:center;justify-content:center;
    background:transparent;
    border:1px solid rgba(245,237,224,.2);color:rgba(245,237,224,.7);
    font-family:var(--fm);font-size:10px;letter-spacing:.14em;
    padding:7px 12px;
    cursor:pointer;transition:border-color .2s,color .2s;
  }
  .return-pill-close:hover{border-color:rgba(245,237,224,.5);color:#f5ede0}
  @media(max-width:640px){
    .return-pill{bottom:72px;padding:6px 8px 6px 12px;gap:8px;font-size:9px}
    .return-pill-btn{padding:6px 10px;font-size:9px}
  }
</style>

<script>
  import { CanvasEngine } from '../components/canvas/engine/CanvasEngine';

  const engine = new CanvasEngine({
    canvasEl: document.getElementById('canvas')!,
    canvasWrap: document.getElementById('canvasWrap')!,
    minimap: document.getElementById('minimap')!,
    minimapCanvas: document.getElementById('minimapCanvas')!,
    minimapViewport: document.getElementById('minimapViewport')!,
    zoomLabel: document.getElementById('zoomVal')!,
    zones: {
      top:      { cx: 2500, cy: 1000, scale: 0.55 },
      problem:  { cx: 2500, cy: 2300, scale: 0.55 },
      solution: { cx: 2500, cy: 4200, scale: 0.55 },
      outcome:  { cx: 2500, cy: 6200, scale: 0.55 },
    },
    zoneBounds: {
      top:      { x1: 1000, y1: 500,  x2: 4000, y2: 1800 },
      problem:  { x1: 1000, y1: 1800, x2: 4000, y2: 3300 },
      solution: { x1: 1000, y1: 3300, x2: 4000, y2: 5600 },
      outcome:  { x1: 1000, y1: 5600, x2: 4000, y2: 6800 },
    },
    canvasWidth: 5000,
    canvasHeight: 6800,
    mode: 'case',
  });

  (window as any).__canvasEngine = engine;

  document.getElementById('btnZoomIn')?.addEventListener('click', () => engine.zoomIn());
  document.getElementById('btnZoomOut')?.addEventListener('click', () => engine.zoomOut());
  document.getElementById('btnFit')?.addEventListener('click', () => engine.fit());
  document.getElementById('btnReader')?.addEventListener('click', () => {
    engine.setReadingMode(true);
  });

  // Margin-ref click → jumpToArtifact (MARGIN-REF-SPEC.md §4)
  document.querySelectorAll<HTMLElement>('.r-margin-ref[data-jump]').forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const slug = link.dataset.jump;
      if (!slug) return;
      engine.jumpToArtifact(slug);
    });
  });

  // Return pill buttons
  document.getElementById('returnPillBtn')?.addEventListener('click', () => {
    engine.restoreFromJump();
    engine.hideReturnPill();
  });

  document.getElementById('returnPillClose')?.addEventListener('click', () => {
    engine.hideReturnPill();
    // Does NOT clear preJumpState — R key still works as silent fallback
  });

  // Mobile hint: show briefly on first mobile visit, then auto-hide
  const mobileHint = document.getElementById('mobileHint');
  if (mobileHint && sessionStorage.getItem('sivanesh.mobileHintSeen') !== '1') {
    const mq = matchMedia('(max-width:820px)');
    if (mq.matches) {
      setTimeout(() => mobileHint.classList.add('on'), 800);
      setTimeout(() => {
        mobileHint.classList.remove('on');
        sessionStorage.setItem('sivanesh.mobileHintSeen', '1');
      }, 5000);
    }
  }

  // Theme toggle
  document.getElementById('themeToggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const next = isDark ? '' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('sivanesh.theme', next);
  });

  // Opening transition — polaroid zoom intro
  const opening = document.getElementById('opening');
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (opening && !reduceMotion) {
    setTimeout(() => {
      opening.classList.add('go');
      setTimeout(() => { opening.style.display = 'none'; }, 1000);
    }, 200);
  } else if (opening) {
    opening.style.display = 'none';
  }
</script>
