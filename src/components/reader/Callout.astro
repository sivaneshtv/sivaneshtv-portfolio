---
interface Props { label?: string }
const { label = 'the hard part' } = Astro.props;
---
<div class="r-callout" data-label={label}>
  <slot />
</div>

<style>
  /* §5.5 */
  .r-callout{
    margin:24px 0;padding:20px 24px;
    background:rgba(245,200,74,.18);
    border-left:3px solid var(--yellow);
    position:relative;
  }
  .r-callout::before{
    content:attr(data-label);position:absolute;top:-9px;left:16px;
    font-family:var(--fm);font-size:8px;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-3);
    background:var(--paper);padding:0 8px;
  }
  .r-callout :global(p){
    font-family:var(--fk);font-weight:400;font-size:17px;line-height:1.55;color:var(--ink);
    margin:0;max-width:none;
  }
  .r-callout :global(p em){color:var(--red)}
</style>
